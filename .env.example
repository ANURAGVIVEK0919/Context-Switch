# ContextSwitch Backend — Environment Variables

# Your Groq API key — get a FREE one at https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Port for the Express HTTP API server (default: 3001)
PORT=3001

# Port for the WebSocket server that receives VS Code extension events (default: 3002)
WS_PORT=3002
